# Memento MCP minimal environment example
# 작성자: 최진호
# 작성일: 2026-03-13

# Server
PORT=57332
SESSION_TTL_MINUTES=60
LOG_DIR=./logs

# Authentication
MEMENTO_ACCESS_KEY=change-me

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memento
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/memento

# pgvector extension schema (auto-detected if unset)
# PGVECTOR_SCHEMA=

# Redis
REDIS_ENABLED=false
CACHE_ENABLED=false

# Embedding
# Leave empty for minimal bootstrap. Add later if semantic search is needed.
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=

# NLI
# Leave empty for minimal bootstrap.
# NLI_SERVICE_URL=
