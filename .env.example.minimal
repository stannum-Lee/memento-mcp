# Memento MCP minimal environment example
# 작성자: 최진호
# 작성일: 2026-03-13

# Server
PORT=57332
SESSION_TTL_MINUTES=60
LOG_DIR=./logs

# Authentication
MEMENTO_ACCESS_KEY=change-me

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memento
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/memento

# pgvector가 public이 아닌 별도 스키마에 설치된 경우 지정 (선택).
# 미설정 시 서버 시작 및 마이그레이션에서 pg_extension으로 자동 감지.
# 대부분의 환경에서는 비워두면 된다.
# PGVECTOR_SCHEMA=

# Redis
REDIS_ENABLED=false
CACHE_ENABLED=false

# Embedding
# Leave empty for minimal bootstrap. Add later if semantic search is needed.
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=

# NLI
# Leave empty for minimal bootstrap.
# NLI_SERVICE_URL=
