{
  "name": "memento-mcp",
  "version": "2.4.0",
  "license": "Apache-2.0",
  "description": "Fragment-Based Memory MCP Server",
  "main": "server.js",
  "type": "module",
  "bin": {
    "memento-mcp": "bin/memento.js"
  },
  "scripts": {
    "start": "node server.js",
    "test": "npm run test:jest && npm run test:unit:node",
    "test:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --selectProjects unit",
    "test:unit:node": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js tests/e2e/*.test.js",
    "test:e2e": "node --test tests/e2e/*.test.js",
    "test:e2e:local": "bash scripts/run-e2e-tests.sh",
    "test:ci": "npm test && npm run test:e2e",
    "lint": "eslint . --max-warnings 0",
    "backfill:embeddings": "node scripts/backfill-embeddings.js",
    "migrate": "node scripts/migrate.js",
    "cli": "node bin/memento.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.0.0",
    "ioredis": "^5.9.3",
    "js-tiktoken": "^1.0.21",
    "node-fetch": "^3.3.2",
    "openai": "^6.21.0",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^30.2.0"
  }
}
