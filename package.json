{
  "name": "memento-mcp",
  "version": "1.2.0",
  "license": "Apache-2.0",
  "description": "Fragment-Based Memory MCP Server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "local:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup_local_windows.ps1",
    "local:start": "wscript //nologo scripts\\start_local_overlay_left.vbs",
    "local:start:service": "wscript //nologo scripts\\start_local_background.vbs",
    "local:start:console": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start_local_windows.ps1",
    "local:stop": "wscript //nologo scripts\\stop_local_silent.vbs",
    "local:stop:service": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop_local_windows.ps1",
    "local:overlay": "wscript //nologo scripts\\start_local_overlay.vbs",
    "local:overlay:left": "wscript //nologo scripts\\start_local_overlay_left.vbs",
    "local:stop:silent": "wscript //nologo scripts\\stop_local_silent.vbs",
    "lint": "eslint .",
    "backfill:embeddings": "node lib/memory/backfill-embeddings.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ioredis": "^5.9.3",
    "js-tiktoken": "^1.0.21",
    "node-fetch": "^3.3.2",
    "openai": "^6.21.0",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^30.2.0"
  }
}
