# Memento MCP 환경변수 샘플
# 복사 후 .env로 사용: cp .env.example .env
# 작성일: 2026-03-03

# ─────────────────────────────────────────
# 서버
# ─────────────────────────────────────────
PORT=57332
SESSION_TTL_MINUTES=60
LOG_DIR=/var/log/mcp

# ─────────────────────────────────────────
# 인증
# 설정 시 모든 요청에 Bearer 토큰 필수
# ─────────────────────────────────────────
# MEMENTO_ACCESS_KEY=your-master-key-here

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT=30000

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
CACHE_ENABLED=true
CACHE_DB_TTL=300
# CACHE_SESSION_TTL=3600  # 기본값: SESSION_TTL_MINUTES와 동일

# Redis Sentinel (선택 — 고가용성 구성 시)
# REDIS_SENTINEL_ENABLED=true
# REDIS_MASTER_NAME=mymaster
# REDIS_SENTINELS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# ── Embedding Provider ──────────────────────────────────────────
# 지원값: openai (기본) | gemini | ollama | localai | transformers | custom
EMBEDDING_PROVIDER=openai

# OpenAI (EMBEDDING_PROVIDER=openai, 기본값)
OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small   # 기본값, 생략 가능
# EMBEDDING_DIMENSIONS=1536                 # 기본값, 생략 가능

# Google Gemini (EMBEDDING_PROVIDER=gemini)
# text-embedding-004는 2026-01-14 종료. 현재 권장: gemini-embedding-001
# EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# EMBEDDING_MODEL=gemini-embedding-001      # 기본값, 생략 가능
# EMBEDDING_DIMENSIONS=3072                 # 기본값, 생략 가능
# ※ 3072차원 최초 사용 시 migration-007 실행 필요:
#   EMBEDDING_DIMENSIONS=3072 DATABASE_URL=$DATABASE_URL node lib/memory/migration-007-flexible-embedding-dims.js

# Ollama 로컬 서버 (EMBEDDING_PROVIDER=ollama)
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text          # 기본값, 생략 가능
# EMBEDDING_DIMENSIONS=768                  # 기본값, 생략 가능
# ※ 1536이 아닌 차원(예: 768) 사용 시 migration-007 실행 필요:
#   EMBEDDING_DIMENSIONS=768 DATABASE_URL=$DATABASE_URL node lib/memory/migration-007-flexible-embedding-dims.js

# LocalAI (EMBEDDING_PROVIDER=localai)
# EMBEDDING_PROVIDER=localai
# EMBEDDING_MODEL=text-embedding-ada-002    # 기본값, 생략 가능

# 로컬 Transformers (EMBEDDING_PROVIDER=transformers)
# API 키 없이 CPU/ONNX Runtime로 동작. 첫 실행 시 모델 다운로드 가능
# EMBEDDING_PROVIDER=transformers
# EMBEDDING_MODEL=Xenova/bge-m3             # 기본값, 생략 가능
# EMBEDDING_DIMENSIONS=1024                 # 기본값, 생략 가능
# MEMENTO_TRANSFORMERS_CACHE=.cache/transformers
# ※ 1536이 아닌 차원(예: 1024) 사용 시 migration-007 실행 필요:
#   EMBEDDING_DIMENSIONS=1024 DATABASE_URL=$DATABASE_URL node lib/memory/migration-007-flexible-embedding-dims.js

# 커스텀 OpenAI 호환 서버 (EMBEDDING_PROVIDER=custom)
# EMBEDDING_PROVIDER=custom
# EMBEDDING_BASE_URL=http://my-server:8080/v1
# EMBEDDING_API_KEY=my-api-key
# EMBEDDING_MODEL=my-model
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_SUPPORTS_DIMS_PARAM=false       # dimensions 파라미터 지원 여부 (기본: false)

# ─────────────────────────────────────────
# NLI 분류기 (선택 — 외부 서비스 사용 시)
# 미설정 시 in-process ONNX 모델 자동 사용
# ─────────────────────────────────────────
# NLI_SERVICE_URL=http://localhost:8080
# NLI_TIMEOUT_MS=5000
