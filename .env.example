# Memento MCP 환경변수 샘플
# 복사 후 .env로 사용: cp .env.example .env
# 작성일: 2026-03-03

# ─────────────────────────────────────────
# 서버
# ─────────────────────────────────────────
PORT=57332
SESSION_TTL_MINUTES=60
LOG_DIR=/var/log/mcp

# ─────────────────────────────────────────
# 인증
# 설정 시 모든 요청에 Bearer 토큰 필수
# ─────────────────────────────────────────
# MEMENTO_ACCESS_KEY=your-master-key-here

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT=30000

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
CACHE_ENABLED=true
CACHE_DB_TTL=300
# CACHE_SESSION_TTL=3600  # 기본값: SESSION_TTL_MINUTES와 동일

# Redis Sentinel (선택 — 고가용성 구성 시)
# REDIS_SENTINEL_ENABLED=true
# REDIS_MASTER_NAME=mymaster
# REDIS_SENTINELS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# ─────────────────────────────────────────
# 임베딩 (시맨틱 검색용 — 선택)
# ─────────────────────────────────────────
# OpenAI 사용 시
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# OpenAI 호환 로컬 서버 사용 시 (Ollama, LocalAI, LM Studio 등)
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768

# ─────────────────────────────────────────
# NLI 분류기 (선택 — 외부 서비스 사용 시)
# 미설정 시 in-process ONNX 모델 자동 사용
# ─────────────────────────────────────────
# NLI_SERVICE_URL=http://localhost:8080
# NLI_TIMEOUT_MS=5000
